# Copy this file to .env and fill in real values. Never commit .env to source control.

# Database
DB_USERNAME=
DB_PASSWORD=

# RabbitMQ
RABBITMQ_USERNAME=
RABBITMQ_PASSWORD=

# JWT — use a long random string, e.g.: openssl rand -base64 64
JWT_SECRET=

# Internal service-to-service token — use a strong random value, e.g.: openssl rand -hex 32
INTERNAL_SERVICE_SECRET=
