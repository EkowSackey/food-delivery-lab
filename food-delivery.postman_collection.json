      "item": [
        {
          "name": "Register customer",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "if (pm.response.code === 200) {",
                "  const j = pm.response.json();",
                "  pm.collectionVariables.set('CUSTOMER_TOKEN', j.token);",
                "  pm.collectionVariables.set('CUSTOMER_ID', j.customerId);",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{BASE_URL}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"johndoe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"secret123\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"phone\": \"+1234567890\",\n  \"deliveryAddress\": \"123 Main St\",\n  \"city\": \"Accra\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Register owner (ownerjan)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{BASE_URL}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"ownerjan\",\n  \"email\": \"owner@example.com\",\n  \"password\": \"secret123\",\n  \"firstName\": \"Jan\",\n  \"lastName\": \"Owner\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Registers with CUSTOMER role. **Before running '1.4 Login as owner', promote this account via:**\n\n```\ndocker exec -it postgres psql -U postgres -d customer_db -c \"UPDATE customers SET role='RESTAURANT_OWNER' WHERE username='ownerjan';\"\n```"
          }
        },
        {
          "name": "Login as customer",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "if (pm.response.code === 200) {",
                "  const j = pm.response.json();",
                "  pm.collectionVariables.set('CUSTOMER_TOKEN', j.token);",
                "  pm.collectionVariables.set('CUSTOMER_ID', j.customerId);",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{BASE_URL}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"johndoe\",\n  \"password\": \"secret123\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
