      "name": "7 · Async Flow — Delivery Verification",
      "description": "These requests verify the RabbitMQ-driven delivery flow. After placing an order, the delivery-service automatically creates a delivery record. Poll the order until `deliveryId` is populated (may take a few seconds).",
      "item": [
        {
          "name": "Poll order — check deliveryId populated",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('deliveryId is set (async delivery created)', () => {",
                "  pm.expect(pm.response.json().deliveryId).to.not.be.null;",
                "});"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{CUSTOMER_TOKEN}}" }],
            "url": "{{BASE_URL}}/api/orders/{{ORDER_ID}}",
            "description": "Re-run this request a few seconds after placing the order. The `deliveryId` field should be populated once the delivery-service has consumed the `OrderPlacedEvent` from RabbitMQ."
          }
        },
        {
          "name": "Verify cancelled order — delivery status FAILED",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Order is CANCELLED', () => pm.expect(pm.response.json().status).to.equal('CANCELLED'));"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{CUSTOMER_TOKEN}}" }],
            "url": "{{BASE_URL}}/api/orders/{{ORDER_ID_2}}",
            "description": "ORDER_ID_2 was cancelled in folder 5. Its delivery should have been set to FAILED via the `OrderCancelledEvent` RabbitMQ flow."
          }
        }
